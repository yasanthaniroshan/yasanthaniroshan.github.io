---
import type { Project } from '../data/projects';

interface Props {
	project: Project;
}

const { project } = Astro.props;
---

<article class="project">
	<h3>
		<a href={project.github} rel="noopener">{project.name}</a>
		{project.highlight && <span class="star">★ {project.highlight}</span>}
	</h3>
	<p>{project.description}</p>
	<ul class="tags">
		{project.tech.map((t) => <li>{t}</li>)}
	</ul>
</article>
