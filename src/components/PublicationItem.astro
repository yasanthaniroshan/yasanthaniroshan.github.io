---
import { AUTHOR_SELF, type Publication } from '../data/publications';

interface Props {
	publication: Publication;
}

const { publication: pub } = Astro.props;
---

<article class="publication">
	<p>
		{
			pub.authors.map((author, i) => (
				<>
					{author === AUTHOR_SELF ? <strong>{author}</strong> : author}
					{i < pub.authors.length - 1 && ', '}
				</>
			))
		}
	</p>
	<p><em>{pub.title}</em></p>
	<p class="venue">
		{pub.venue}, {pub.year}.
		{pub.doi && (
			<>
				{' '}<a href={`https://doi.org/${pub.doi}`} rel="noopener">doi:{pub.doi}</a>
			</>
		)}
		{pub.link && (
			<>
				{' '}· <a href={pub.link} rel="noopener">full text</a>
			</>
		)}
	</p>
	{
		pub.bibtex && (
			<details>
				<summary>BibTeX</summary>
				<pre><code>{pub.bibtex}</code></pre>
			</details>
		)
	}
</article>
