---
import { AUTHOR_MATCH, type Publication } from '../data/publications';

interface Props {
	publication: Publication;
}

const { publication: pub } = Astro.props;

const isArxiv = pub.link?.includes('arxiv.org') ?? false;
const linkLabel = isArxiv ? 'arXiv' : pub.type === 'dataset' ? 'Data' : 'Paper';
---

<article class="publication">
	<p class="pub-title">{pub.title}</p>
	<p>
		{
			pub.authors.map((author, i) => (
				<>
					{author.includes(AUTHOR_MATCH) ? <strong>{author}</strong> : author}
					{i < pub.authors.length - 1 && ', '}
				</>
			))
		}
	</p>
	<p class="venue">{pub.venue} · {pub.year}</p>
	<div class="pub-links">
		{
			pub.link && (
				<a href={pub.link} rel="noopener">
					{isArxiv ? (
						<svg viewBox="0 0 16 16" aria-hidden="true">
							<path
								d="M3 2l10 12M13 2L3 14"
								stroke="currentColor"
								stroke-width="1.8"
								fill="none"
								stroke-linecap="round"
							/>
						</svg>
					) : pub.type === 'dataset' ? (
						<svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
							<path d="M8 1C4.69 1 2 1.9 2 3s2.69 2 6 2 6-.9 6-2-2.69-2-6-2zM2 5.5V8c0 1.1 2.69 2 6 2s6-.9 6-2V5.5c-1.28.85-3.56 1.3-6 1.3S3.28 6.35 2 5.5zM2 10v2.5c0 1.1 2.69 2 6 2s6-.9 6-2V10c-1.28.85-3.56 1.3-6 1.3S3.28 10.85 2 10z" />
						</svg>
					) : (
						<svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
							<path d="M9.5 0H4a1 1 0 0 0-1 1v14a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V3.5L9.5 0zM9 4V1.5L11.5 4H9zM5 7h6v1.2H5V7zm0 3h6v1.2H5V10z" />
						</svg>
					)}
					{linkLabel}
				</a>
			)
		}
		{
			pub.doi && (
				<a href={`https://doi.org/${pub.doi}`} rel="noopener">
					<svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
						<path d="M7.775 3.275a.75.75 0 0 0 1.06 1.06l1.25-1.25a2 2 0 1 1 2.83 2.83l-2.5 2.5a2 2 0 0 1-2.83 0 .75.75 0 0 0-1.06 1.06 3.5 3.5 0 0 0 4.95 0l2.5-2.5a3.5 3.5 0 0 0-4.95-4.95l-1.25 1.25zm-4.69 9.64a2 2 0 0 1 0-2.83l2.5-2.5a2 2 0 0 1 2.83 0 .75.75 0 0 0 1.06-1.06 3.5 3.5 0 0 0-4.95 0l-2.5 2.5a3.5 3.5 0 0 0 4.95 4.95l1.25-1.25a.75.75 0 0 0-1.06-1.06l-1.25 1.25a2 2 0 0 1-2.83 0z" />
					</svg>
					DOI
				</a>
			)
		}
		{
			pub.code && (
				<a href={pub.code} rel="noopener">
					<svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
						<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
					</svg>
					Code
				</a>
			)
		}
		{
			pub.bibtex && (
				<details>
					<summary>
						<svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
							<path d="M1.75 2.5h10.5a.75.75 0 0 1 0 1.5H1.75a.75.75 0 0 1 0-1.5zm4 5h8.5a.75.75 0 0 1 0 1.5h-8.5a.75.75 0 0 1 0-1.5zm0 5h8.5a.75.75 0 0 1 0 1.5h-8.5a.75.75 0 0 1 0-1.5zM2.5 7.75v6a.75.75 0 0 1-1.5 0v-6a.75.75 0 0 1 1.5 0z" />
						</svg>
						BibTeX
					</summary>
					<pre><code>{pub.bibtex}</code></pre>
				</details>
			)
		}
	</div>
</article>
